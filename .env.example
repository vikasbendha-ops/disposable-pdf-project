# Next.js frontend (optional in same-origin Vercel deployment)
NEXT_PUBLIC_BACKEND_URL=

# Backend runtime environment (used by Vercel Python functions)
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_SECRET_KEY=<optional-secret-key>
SUPABASE_STORAGE_BUCKET=secure-pdfs
SUPABASE_FORCE_REST=false
SUPABASE_AUTO_DISCOVER_POOLER=true
SUPABASE_POOLER_DISCOVERY_TIMEOUT=2.0
# SUPABASE_POOLER_REGIONS=ap-northeast-1,us-east-1

MONGO_URL=mongodb://localhost:27017
DB_NAME=autodestroy

# Comma-separated frontend origins
CORS_ORIGINS=https://your-domain.vercel.app,http://localhost:3000
