# Optional override for frontend API target.
# Leave empty for same-origin /api in local + Vercel.
NEXT_PUBLIC_BACKEND_URL=

# Supabase Postgres connection used by Next.js API (required).
# If password has special chars, URL-encode them (e.g. # => %23, ! => %21).
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@<pooler-host>:6543/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_STORAGE_BUCKET=secure-pdfs
SUPABASE_AUTO_DISCOVER_POOLER=true
SUPABASE_POOLER_DISCOVERY_TIMEOUT=2.0
# SUPABASE_POOLER_REGIONS=ap-northeast-1,us-east-1

# Build-time DB migration behavior
# On Vercel production deploys, migration runs by default.
# Override with RUN_DB_MIGRATIONS_ON_BUILD=true/false.
RUN_DB_MIGRATIONS_ON_BUILD=true
# Emergency flag to skip migration even when enabled
SKIP_DB_MIGRATE=false

# App security
JWT_SECRET_KEY=<long-random-secret>
APP_BASE_URL=https://securepdf.yourdomain.com
SUPER_ADMIN_EMAILS=connect@vikasbendha.com

# Email verification / password reset
RESEND_API_KEY=<optional-resend-api-key>
EMAIL_FROM=no-reply@your-domain.com
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_MINUTES=60
AUTH_DEBUG_TOKENS=false

# Storage provider
DEFAULT_STORAGE_PROVIDER=supabase_db
WASABI_ENDPOINT=
WASABI_REGION=us-east-1
WASABI_BUCKET=
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_FORCE_PATH_STYLE=true

# Optional Stripe settings
STRIPE_API_KEY=<optional-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<optional-stripe-webhook-secret>

# Comma-separated frontend origins
CORS_ORIGINS=https://securepdf.yourdomain.com,https://your-domain.vercel.app,http://localhost:3000

# Custom domain verification + DNS targets
CUSTOM_DOMAIN_TXT_PREFIX=_autodestroy
CUSTOM_DOMAIN_VERCEL_CNAME_TARGET=cname.vercel-dns.com
# Optional extra accepted CNAME targets, comma-separated
CUSTOM_DOMAIN_CNAME_TARGETS=
# Optional A targets for apex domains, comma-separated
CUSTOM_DOMAIN_A_TARGETS=76.76.21.21
CUSTOM_DOMAIN_VERIFY_TIMEOUT_MS=6000

# Optional seed settings (used by npm run db:seed)
SEED_ADMIN_EMAIL=admin@autodestroy.local
SEED_ADMIN_PASSWORD=Admin@123456
SEED_CREATE_SAMPLE_USER=true
SEED_USER_EMAIL=connect@vikasbendha.com
SEED_USER_PASSWORD=User@123456
